<config>
    <sections>
        <payment>
            <groups>
                <maho_revolut_credentials translate="label">
                    <label>Revolut - General Settings</label>
                    <sort_order>300</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>0</show_in_store>
                    <expanded>1</expanded>
                    <fields>
                        <sandbox translate="label comment">
                            <label>Sandbox Mode</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>maho_revolut/credentials/sandbox</config_path>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment>Use Revolut sandbox environment for testing.</comment>
                        </sandbox>
                        <api_key translate="label comment">
                            <label>Merchant API Key</label>
                            <frontend_type>obscure</frontend_type>
                            <backend_model>adminhtml/system_config_backend_encrypted</backend_model>
                            <config_path>maho_revolut/credentials/api_key</config_path>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment><![CDATA[In your Revolut Business dashboard (production: <a href="https://business.revolut.com" target="_blank">business.revolut.com</a>, sandbox: <a href="https://sandbox-business.revolut.com" target="_blank">sandbox-business.revolut.com</a>) go to <b>Merchant &rarr; APIs &rarr; Merchant API</b> tab and copy the <b>Sandbox / Production API Secret key</b> (<code>sk_...</code>). The Business API and the Public key are not used by this module.]]></comment>
                        </api_key>
                        <webhook_secret translate="label comment">
                            <label>Webhook Signing Secret</label>
                            <frontend_type>obscure</frontend_type>
                            <backend_model>adminhtml/system_config_backend_encrypted</backend_model>
                            <config_path>maho_revolut/credentials/webhook_secret</config_path>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment><![CDATA[In the same Revolut dashboard go to <b>Merchant &rarr; APIs &rarr; Merchant API &rarr; Webhooks</b> and add a webhook pointing to <code>&lt;your-store&gt;/revolut/webhook</code>. Subscribe to at least <code>ORDER_COMPLETED</code>, <code>ORDER_AUTHORISED</code>, <code>ORDER_CANCELLED</code>, <code>ORDER_PAYMENT_FAILED</code>. Revolut shows the signing secret once after saving — paste it here.]]></comment>
                        </webhook_secret>
                    </fields>
                </maho_revolut_credentials>

                <revolut_pay translate="label">
                    <label>Revolut - Revolut Pay</label>
                    <sort_order>301</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <active translate="label">
                            <label>Enabled</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>payment/revolut_pay/active</config_path>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                        </active>
                        <title translate="label">
                            <label>Title</label>
                            <frontend_type>text</frontend_type>
                            <config_path>payment/revolut_pay/title</config_path>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </title>
                        <payment_action translate="label">
                            <label>Payment Action</label>
                            <frontend_type>select</frontend_type>
                            <source_model>maho_revolut/system_config_source_paymentAction</source_model>
                            <config_path>payment/revolut_pay/payment_action</config_path>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment>"Authorize and Capture" captures funds immediately. "Authorize Only" reserves them; capture later via invoice.</comment>
                        </payment_action>
                        <allowspecific translate="label">
                            <label>Payment from Applicable Countries</label>
                            <frontend_type>allowspecific</frontend_type>
                            <source_model>adminhtml/system_config_source_payment_allspecificcountries</source_model>
                            <config_path>payment/revolut_pay/allowspecific</config_path>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                        </allowspecific>
                        <specificcountry translate="label">
                            <label>Payment from Specific Countries</label>
                            <frontend_type>multiselect</frontend_type>
                            <source_model>adminhtml/system_config_source_country</source_model>
                            <config_path>payment/revolut_pay/specificcountry</config_path>
                            <sort_order>50</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                            <depends>
                                <allowspecific>1</allowspecific>
                            </depends>
                        </specificcountry>
                        <sort_order translate="label">
                            <label>Sort Order</label>
                            <frontend_type>text</frontend_type>
                            <config_path>payment/revolut_pay/sort_order</config_path>
                            <sort_order>60</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                        </sort_order>
                    </fields>
                </revolut_pay>
            </groups>
        </payment>
    </sections>
</config>
