{
    "name": "mahocommerce/module-revolut",
    "description": "Revolut payment gateway integration for Maho",
    "license": "OSL-3.0",
    "type": "maho-module",
    "require": {
        "php": ">=8.3"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "friendsofphp/php-cs-fixer": "*",
        "mahocommerce/maho": "dev-main",
        "mahocommerce/maho-phpstan-plugin": "*",
        "phpstan/phpstan": "*",
        "phpstan/phpstan-deprecation-rules": "*",
        "phpstan/phpstan-strict-rules": "*",
        "rector/rector": "*"
    },
    "config": {
        "allow-plugins": {
            "mahocommerce/maho-composer-plugin": true
        },
        "platform": {
            "php": "8.3"
        }
    }
}
